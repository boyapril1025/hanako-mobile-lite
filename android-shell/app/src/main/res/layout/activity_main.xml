<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/status_bar_bg">

    <WebView
        android:id="@+id/web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/error_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/error_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/error_title"
            android:textColor="@color/error_title"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/error_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="@string/error_default_detail"
            android:textColor="@color/error_detail"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="160dp"
            android:text="@string/btn_retry"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_change_url"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:minWidth="160dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_change_url"
            android:textSize="14sp"
            android:backgroundTint="@color/error_detail"
            android:textColor="@android:color/white" />
    </LinearLayout>

</FrameLayout>
